load("@pigweed//pw_kernel/tooling:system_image.bzl", "system_image", "system_image_test")
load("@pigweed//pw_kernel/tooling:target_linker_script.bzl", "target_linker_script")
load("@pigweed//pw_kernel/tooling/panic_detector:rust_binary_no_panics_test.bzl", "rust_binary_no_panics_test")
load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//target/ast10x0:defs.bzl", "TARGET_COMPATIBLE_WITH")

filegroup(
    name = "system_config",
    srcs = ["system.json5"],
)

target_linker_script(
    name = "linker_script",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    template = "//target/ast10x0:linker_script_template",
)

rust_binary(
    name = "target",
    srcs = ["target.rs"],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":linker_script",
        "//target/ast10x0:entry",
        "//target/ast10x0/peripherals",
        "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
        "@pigweed//pw_kernel/kernel",
        "@pigweed//pw_kernel/subsys/console:console_backend",
        "@pigweed//pw_kernel/target:target_common",
        "@pigweed//pw_log/rust:pw_log",
        "@rust_crates//:cortex-m-semihosting",
    ],
)

system_image(
    name = "smc",
    kernel = ":target",
    platform = "//target/ast10x0",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    userspace = False,
)

system_image_test(
    name = "smc_test",
    image = ":smc",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

rust_binary_no_panics_test(
    name = "no_panics_test",
    binary = ":smc",
    tags = ["kernel"],
)

# ── QEMU-only targets ─────────────────────────────────────────────────────────
# Tagged "integration" so k_common / --config=virt_ast10x0 excludes them.
# Invoke explicitly:
#   bazelisk test --platforms=//target/ast10x0 \
#     //target/ast10x0/tests/smc:smc_qemu_erase_state_test

rust_binary(
    name = "target_qemu",
    srcs = ["target_qemu.rs"],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":linker_script",
        "//target/ast10x0:entry",
        "//target/ast10x0/peripherals",
        "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
        "@pigweed//pw_kernel/kernel",
        "@pigweed//pw_kernel/subsys/console:console_backend",
        "@pigweed//pw_kernel/target:target_common",
        "@pigweed//pw_log/rust:pw_log",
        "@rust_crates//:cortex-m-semihosting",
    ],
)

system_image(
    name = "smc_qemu_erase_state",
    kernel = ":target_qemu",
    platform = "//target/ast10x0",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    userspace = False,
)

system_image_test(
    name = "smc_qemu_erase_state_test",
    image = ":smc_qemu_erase_state",
    tags = [
        "kernel",
        "integration",  # excluded by k_common; QEMU-only
    ],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

