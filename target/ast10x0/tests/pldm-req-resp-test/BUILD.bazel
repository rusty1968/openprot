load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library")
load("//target/ast10x0:defs.bzl", "TARGET_COMPATIBLE_WITH")
load("@pigweed//pw_kernel/tooling:app_linker_script.bzl", "app_linker_script")
load("@pigweed//pw_kernel/tooling:rust_app.bzl", "rust_app_codegen")
load("@pigweed//pw_kernel/tooling:system_image.bzl", "system_image", "system_image_test")
load("@pigweed//pw_kernel/tooling:target_codegen.bzl", "target_codegen")
load("@pigweed//pw_kernel/tooling:target_linker_script.bzl", "target_linker_script")
load("@pigweed//pw_kernel/tooling/panic_detector:rust_binary_no_panics_test.bzl", "rust_binary_no_panics_test")

# ---------------------------------------------------------------------------
# System image: loopback server + PLDM requester + PLDM responder
# ---------------------------------------------------------------------------

system_image(
    name = "pldm_req_resp_test",
    apps = [
        ":mctp_loopback_server_app",
        ":pldm_requester_app",
        ":pldm_responder_app",
    ],
    kernel = ":target",
    platform = "//target/ast10x0",
    system_config = ":system_config",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
)

system_image_test(
    name = "pldm_req_resp_test_test",
    image = ":pldm_req_resp_test",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

rust_binary_no_panics_test(
    name = "no_panics_test",
    binary = ":pldm_req_resp_test",
    tags = ["kernel"],
)

# ---------------------------------------------------------------------------
# Shared test configuration (EID constants)
# ---------------------------------------------------------------------------

rust_library(
    name = "test_config",
    srcs = ["config.rs"],
    crate_name = "test_config",
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        "//services/pldm:pldm_service",
        "@rust_crates//:pldm-common",
        "@rust_crates//:pldm-interface",
    ],
)

# ---------------------------------------------------------------------------
# System configuration
# ---------------------------------------------------------------------------

filegroup(
    name = "system_config",
    srcs = ["system.json5"],
    visibility = ["//visibility:public"],
)

# ---------------------------------------------------------------------------
# Kernel target
# ---------------------------------------------------------------------------

target_codegen(
    name = "codegen",
    arch = "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
    system_config = ":system_config",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

target_linker_script(
    name = "linker_script",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    template = "//target/ast10x0:linker_script_template",
)

rust_binary(
    name = "target",
    srcs = [
        "target.rs",
    ],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":codegen",
        ":linker_script",
        "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
        "@pigweed//pw_kernel/kernel",
        "@pigweed//pw_kernel/subsys/console:console_backend",
        "@pigweed//pw_kernel/target:target_common",
        "//target/ast10x0:entry",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@rust_crates//:cortex-m-semihosting",
    ],
)

# ---------------------------------------------------------------------------
# App 1: MCTP Loopback Server
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_mctp_loopback_server",
    app_name = "mctp_loopback_server",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "mctp_loopback_server_app.linker_script",
    app_name = "mctp_loopback_server",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "mctp_loopback_server_app",
    srcs = [
        "//target/ast10x0/tests/pldm-req-resp-test:mctp_loopback_server.rs",
    ],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_mctp_loopback_server",
        ":mctp_loopback_server_app.linker_script",
        ":test_config",
        "//services/mctp/api:mctp_api",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:mctp",
        "@rust_crates//:mctp-lib",
    ],
)

# ---------------------------------------------------------------------------
# App 2: PLDM Requester
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_pldm_requester",
    app_name = "pldm_requester",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "pldm_requester_app.linker_script",
    app_name = "pldm_requester",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "pldm_requester_app",
    srcs = [
        "pldm_requester.rs",
    ],
    crate_root = "pldm_requester.rs",
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_pldm_requester",
        ":pldm_requester_app.linker_script",
        ":test_config",
        "//services/mctp/api:mctp_api",
        "//services/pldm:pldm_service",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:pldm-common",
        "@rust_crates//:pldm-interface",
    ],
)

# ---------------------------------------------------------------------------
# App 3: PLDM Responder
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_pldm_responder",
    app_name = "pldm_responder",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "pldm_responder_app.linker_script",
    app_name = "pldm_responder",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "pldm_responder_app",
    srcs = [
        "pldm_responder.rs",
    ],
    crate_root = "pldm_responder.rs",
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_pldm_responder",
        ":pldm_responder_app.linker_script",
        ":test_config",
        "//services/mctp/api:mctp_api",
        "//services/pldm:pldm_service",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:pldm-common",
        "@rust_crates//:pldm-interface",
    ],
)
