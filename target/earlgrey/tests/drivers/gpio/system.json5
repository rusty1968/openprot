              size_bytes: 0x40,
            },
            {
              name: "pinmux",
              type: "device",
              start_address: 0x40460000,
              size_bytes: 0x1000,
            }
          ],
          threads: [
            {
              name: "main_thread",
              kernel_stack_size_bytes: 2048,
            },
          ],
        },
      ],
    },
  ],
