load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//target/virt-ast1060-evb:defs.bzl", "TARGET_COMPATIBLE_WITH")
load("@pigweed//pw_kernel/tooling:app_linker_script.bzl", "app_linker_script")
load("@pigweed//pw_kernel/tooling:rust_app.bzl", "rust_app_codegen")
load("@pigweed//pw_kernel/tooling:system_image.bzl", "system_image", "system_image_test")
load("@pigweed//pw_kernel/tooling:target_codegen.bzl", "target_codegen")
load("@pigweed//pw_kernel/tooling:target_linker_script.bzl", "target_linker_script")
load("@pigweed//pw_kernel/tooling/panic_detector:rust_binary_no_panics_test.bzl", "rust_binary_no_panics_test")

# ---------------------------------------------------------------------------
# System image: loopback server + SPDM requester + SPDM responder
# ---------------------------------------------------------------------------

system_image(
    name = "spdm_req_resp_test",
    apps = [
        ":mctp_loopback_server_app",
        ":spdm_requester_app",
        ":spdm_responder_app",
        ":crypto_server_app",
    ],
    kernel = ":target",
    platform = "//target/virt-ast1060-evb",
    system_config = ":system_config",
    tags = ["kernel"],
    visibility = ["//visibility:public"],
)

system_image_test(
    name = "spdm_req_resp_test_test",
    image = ":spdm_req_resp_test",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

rust_binary_no_panics_test(
    name = "no_panics_test",
    binary = ":spdm_req_resp_test",
    tags = ["kernel"],
)

# ---------------------------------------------------------------------------
# System configuration
# ---------------------------------------------------------------------------

filegroup(
    name = "system_config",
    srcs = ["system.json5"],
    visibility = ["//visibility:public"],
)

# ---------------------------------------------------------------------------
# Kernel target
# ---------------------------------------------------------------------------

target_codegen(
    name = "codegen",
    arch = "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
    system_config = ":system_config",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

target_linker_script(
    name = "linker_script",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    template = "//target/virt-ast1060-evb:linker_script_template",
)

rust_binary(
    name = "target",
    srcs = [
        "target.rs",
    ],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":codegen",
        ":linker_script",
        "@pigweed//pw_kernel/arch/arm_cortex_m:arch_arm_cortex_m",
        "@pigweed//pw_kernel/kernel",
        "@pigweed//pw_kernel/subsys/console:console_backend",
        "@pigweed//pw_kernel/target:target_common",
        "//target/virt-ast1060-evb:entry",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@rust_crates//:cortex-m-semihosting",
    ],
)

# ---------------------------------------------------------------------------
# App 1: MCTP Loopback Server
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_mctp_loopback_server",
    app_name = "mctp_loopback_server",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "mctp_loopback_server_app.linker_script",
    app_name = "mctp_loopback_server",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "mctp_loopback_server_app",
    srcs = [
        "//target/ast1060-evb/spdm-req-resp-test:mctp_loopback_server.rs",
    ],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_mctp_loopback_server",
        ":mctp_loopback_server_app.linker_script",
        "//services/mctp/api:mctp_api",
        "//services/mctp/server:mctp_server_lib",
        "//services/mctp/transport-loopback:mctp_transport_loopback",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:mctp",
        "@rust_crates//:mctp-lib",
    ],
)

# ---------------------------------------------------------------------------
# App 2: SPDM Requester
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_spdm_requester",
    app_name = "spdm_requester",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "spdm_requester_app.linker_script",
    app_name = "spdm_requester",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "spdm_requester_app",
    srcs = [
        "spdm_requester.rs",
    ],
    crate_root = "spdm_requester.rs",
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_spdm_requester",
        ":spdm_requester_app.linker_script",
        "//services/mctp/api:mctp_api",
        "//services/mctp/client:mctp_client",
        "//services/spdm/hash:spdm_hash_lib",
        "//services/spdm/rng:spdm_rng_lib",
        "//services/spdm/transport-mctp:spdm_transport_mctp",
        "//target/ast1060-evb/spdm-req-resp-test:mock_platform",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@oot_crates_no_std//:spdm-lib",
        "@rust_crates//:heapless",
        "@rust_crates//:zerocopy",
    ],
)

# ---------------------------------------------------------------------------
# App 3: SPDM Responder
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_spdm_responder",
    app_name = "spdm_responder",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "spdm_responder_app.linker_script",
    app_name = "spdm_responder",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "spdm_responder_app",
    srcs = [
        "spdm_responder.rs",
    ],
    crate_root = "spdm_responder.rs",
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_spdm_responder",
        ":spdm_responder_app.linker_script",
        "//services/mctp/api:mctp_api",
        "//services/mctp/client:mctp_client",
        "//services/spdm/hash:spdm_hash_lib",
        "//services/spdm/rng:spdm_rng_lib",
        "//services/spdm/transport-mctp:spdm_transport_mctp",
        "//target/ast1060-evb/spdm-req-resp-test:mock_platform",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@oot_crates_no_std//:spdm-lib",
        "@rust_crates//:heapless",
        "@rust_crates//:zerocopy",
    ],
)

# ---------------------------------------------------------------------------
# App 4: Crypto Server
# ---------------------------------------------------------------------------

rust_app_codegen(
    name = "app_crypto_server",
    app_name = "crypto_server",
    edition = "2024",
    system_config = ":system_config",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
)

app_linker_script(
    name = "crypto_server_app.linker_script",
    app_name = "crypto_server",
    system_config = ":system_config",
    tags = ["kernel"],
)

rust_binary(
    name = "crypto_server_app",
    srcs = [
        "//services/crypto/server:src/main.rs",
    ],
    edition = "2024",
    tags = ["kernel"],
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    deps = [
        ":app_crypto_server",
        ":crypto_server_app.linker_script",
        "//services/crypto/api:crypto_api",
        "//services/crypto/backend-rustcrypto:crypto-backend-rustcrypto",
        "@pigweed//pw_kernel/syscall:syscall_user",
        "@pigweed//pw_kernel/userspace",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@oot_crates_no_std//:zerocopy",
    ],
)
