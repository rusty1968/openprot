//
// System configuration for async e2e test on qemu_virt_riscv32.
// Single-app, single-thread: just enough to run the executor poll loop.
{
  arch: {
    type: "riscv",
  },
  kernel: {
    flash_start_address: 0x80000000,
    flash_size_bytes: 261120,
    ram_start_address: 0x81000000,
    ram_size_bytes: 65536,
    interrupt_table: {
      table: {}
    },
  },
  apps: [
    {
      name: "async_e2e_test",
      flash_size_bytes: 261120,
      ram_size_bytes: 65536,
      process: {
        name: "async_e2e process",
        objects: [],
        threads: [
          {
            name: "async_e2e thread",
            // Generous stack size pending kernel stack size optimization.
            stack_size_bytes: 2048,
          },
        ],
      },
    },
  ],
}
