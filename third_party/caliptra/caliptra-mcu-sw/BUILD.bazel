# MCU ROM linker script generator
rust_binary(
    name = "generate_rom_ld",
    srcs = ["src/generate_rom_ld.rs"],
    edition = "2021",
    deps = [
        "@rust_caliptra_crates_host//:mcu-config-emulator",
        "@rust_caliptra_crates_host//:subst",
    ],
)

caliptra_linker_script(
    name = "emulator_rom_layout",
    out = "emulator-rom-layout.ld",
    generator = ":generate_rom_ld",
)

# NOTE: This target requires the caliptra RISC-V platform transition to build.
# Build via //target/veer/tooling:mcu_rom_bin_transitioned instead of directly.
rust_binary(
    name = "mcu_rom",
    srcs = ["@caliptra_mcu_sw//:all_files"],
    compile_data = [":emulator-rom-layout.ld"],
    crate_root = "@caliptra_mcu_sw//:platforms/emulator/rom/src/main.rs",
    edition = "2021",
    rustc_flags = [
        "-A",
        "dead_code",
        "-C",
        "link-arg=-T$(location :emulator-rom-layout.ld)",
        "--cap-lints=allow",
        "--cfg",
        'target_arch="riscv32"',
        "-C",
        "panic=abort",
        "-C",
        "target-feature=+relax,+zba,+zbb,+zbc,+zbs",
        "-C",
        "force-frame-pointers=no",
        "-C",
        "relocation-model=static",
        "-C",
        "symbol-mangling-version=v0",
        "-C",
        "link-arg=-Wl,-nmagic",
        "-C",
        "link-arg=-Wl,--icf=all",
    ],
    tags = ["manual"],
    deps = [
        ":mcu_rom_common",
        ":romtime",
        "//third_party/caliptra:crate_bitfield",
        "//third_party/caliptra:crate_smlang",
        "//third_party/caliptra:crate_tock-registers",
        "//third_party/caliptra:crate_zerocopy",
        "//third_party/caliptra:crate_zeroize",
        "//third_party/caliptra/caliptra-sw:caliptra_drivers",
        "@rust_caliptra_crates//:caliptra-api",
        "@rust_caliptra_crates//:caliptra-api-types",
        "@rust_caliptra_crates//:mcu-config",
        "@rust_caliptra_crates//:mcu-config-emulator",
        "@rust_caliptra_crates//:mcu-error",
        "@rust_caliptra_crates//:mcu-image-header",
        "@rust_caliptra_crates//:panic-halt",
        "@rust_caliptra_crates//:registers-generated",
        "@rust_caliptra_crates//:rv32i",
        "@rust_caliptra_crates//:ureg",
    ],
)

caliptra_objcopy(
    name = "mcu_rom_bin",
    src = ":mcu_rom",
    out = "mcu_rom.bin",
    tags = [
        "manual",
        "no-sandbox",
    ],
)
