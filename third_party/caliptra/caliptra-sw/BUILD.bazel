# --- Caliptra ROM ---

# cpp-preprocess start.S (upstream's build.rs does the same step).  Output
# lands in this package's bin dir so OUT_DIR (set on caliptra_rom below) can
# point at it — letting upstream main.rs compile with its verbatim
# `include_str!(concat!(env!("OUT_DIR"), "/start_preprocessed.S"))`.
cc_preprocess(
    name = "rom_start_preprocessed",
    src = "@caliptra_sw//:rom/dev/src/start.S",
    out = "start_preprocessed.S",
    target_compatible_with = ["//third_party/caliptra/platforms:target_caliptra"],
)

# Linker scripts: source files must go through copy genrules so Bazel properly
# symlinks them into the sandbox under platform transitions (rules_rust quirk).
genrule(
    name = "rom_ld_gen",
    srcs = ["rom.ld"],
    outs = ["rom_gen.ld"],
    cmd = "cp $(location rom.ld) $@",
)

genrule(
    name = "link_x_gen",
    srcs = ["link.x"],
    outs = ["link_gen.x"],
    cmd = "cp $(location link.x) $@",
)

genrule(
    name = "fmc_memory_x_gen",
    srcs = ["fmc_memory.x"],
    outs = ["fmc_memory_gen.x"],
    cmd = "cp $(location fmc_memory.x) $@",
)

genrule(
    name = "runtime_memory_x_gen",
    srcs = ["runtime_memory.x"],
    outs = ["runtime_memory_gen.x"],
    cmd = "cp $(location runtime_memory.x) $@",
)

rust_binary(
    name = "caliptra_rom",
    srcs = ["@caliptra_sw//:rom_srcs"],
    compile_data = [
        ":rom_gen.ld",
        ":rom_start_preprocessed",
    ],
    crate_root = "@caliptra_sw//:rom/dev/src/main.rs",
    edition = "2021",
    proc_macro_deps = [
        "@rust_caliptra_crates//:caliptra-cfi-derive",
    ],
    rustc_env = {
        # Upstream main.rs: `include_str!(concat!(env!("OUT_DIR"), "/start_preprocessed.S"))`.
        # rustc resolves the concatenated path relative to main.rs's source
        # directory (external/+caliptra_repos+caliptra_sw/rom/dev/src/), so
        # OUT_DIR walks 5 levels up to execroot and then into $(BINDIR).
        #
        # Alternative considered: stage main.rs into this package's bin dir so
        # OUT_DIR="." works. Rejected — Rust resolves `mod crypto;`
        # /`mod exception;`/… relative to the file they're declared in, so
        # moving main.rs would require either (a) staging every submodule
        # too (reintroducing the enumerated `outs=[...]` brittleness this
        # refactor just removed), or (b) a hand-maintained shim that
        # #[path]-redirects each submodule (one new source of drift per
        # upstream module add/rename). The "5 `..` + $(BINDIR)" path depends
        # only on Bazel's stable external-repo layout plus upstream's
        # `rom/dev/src/` depth — one well-commented invariant, not dozens.
        "OUT_DIR": "../../../../../$(BINDIR)/third_party/caliptra/caliptra-sw",
    },
    rustc_flags = [
        "-A",
        "mismatched_lifetime_syntaxes",
        "-C",
        "link-arg=-T$(execpath :rom_gen.ld)",
        "-C",
        "panic=abort",
        "-C",
        "opt-level=s",
        "-C",
        "codegen-units=1",
        "-C",
        "lto=fat",
        "-C",
        "embed-bitcode=yes",
        "-C",
        "link-arg=-Wl,--relax",
        "-C",
        "link-arg=-Wl,-Map=caliptra_rom.map",
    ],
    target_compatible_with = ["//third_party/caliptra/platforms:target_caliptra"],
    deps = [
        ":caliptra_cfi_lib",
        ":caliptra_common",
        ":caliptra_drivers",
        ":caliptra_image_verify",
        ":caliptra_kat",
        "//third_party/caliptra:crate_memoffset",
        "//third_party/caliptra:crate_zerocopy",
        "//third_party/caliptra:crate_zeroize",
        "@rust_caliptra_crates//:caliptra-api",
        "@rust_caliptra_crates//:caliptra-error",
        "@rust_caliptra_crates//:caliptra-image-types",
        "@rust_caliptra_crates//:caliptra-lms-types",
        "@rust_caliptra_crates//:caliptra-registers",
        "@rust_caliptra_crates//:caliptra-x509",
        "@rust_caliptra_crates//:ufmt",
    ],
)

