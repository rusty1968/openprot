# Local caliptra_emu_bus / caliptra_emu_cpu / caliptra_emu_periph / caliptra_emu_derive:
# these sw-emulator host libraries mix deps from both crate_universe workspaces —
# caliptra-emu-types lives in @rust_caliptra_crates_host, while ureg only exists in
# @rust_caliptra_crates (no host-workspace entry, since ureg is the register
# codegen library for embedded caliptra). Migrating the emu chain to crate_universe
# would force every dep into one workspace and produce TypeId mismatches at the
# trait boundaries where emu-bus types meet ureg/registers types (two rlibs of the
# same source, different workspace-qualified names). Hand-written rust_library
# wrappers let us thread the cross-workspace mix explicitly.

rust_library(
    name = "caliptra_emu_bus",
    srcs = ["@caliptra_sw//:emu_bus_srcs"],
    crate_name = "caliptra_emu_bus",
    crate_root = "@caliptra_sw//:sw-emulator/lib/bus/src/lib.rs",
    edition = "2021",
    deps = [
        "//third_party/caliptra:crate_tock-registers",
        "@rust_caliptra_crates//:ureg",
        "@rust_caliptra_crates_host//:caliptra-emu-types",
    ],
)

