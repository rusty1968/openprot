# Local rust_library wrappers for caliptra-cfi-lib and caliptra-drivers. These
# are kept out of crate_universe on purpose: upstream caliptra-sw/Cargo.toml
# pins `caliptra-cfi-lib = { features = ["cfi", "cfi-counter"] }` on
# caliptra-drivers unconditionally, so a crate_universe-managed build would
# compile cfi-lib with runtime CFI checks active, pushing the ROM binary past
# the 96 KB emulator limit (measured: 102268 vs 98304). Hand-written
# rust_library rules do not pass crate_features, so cfi-lib's
# `cfg!(feature = "cfi")` branches fold to no-ops and the ROM fits.
rust_library(
    name = "caliptra_cfi_lib",
    srcs = ["@caliptra_sw//:all_files"],
    crate_root = "@caliptra_sw//:cfi/lib/src/lib.rs",
    edition = "2021",
    deps = [
        "@rust_caliptra_crates//:caliptra-error",
        "@rust_caliptra_crates//:caliptra-registers",
    ],
)

rust_library(
    name = "caliptra_drivers",
    srcs = ["@caliptra_sw//:all_files"],
    crate_root = "@caliptra_sw//:drivers/src/lib.rs",
    edition = "2021",
    proc_macro_deps = [
        "@rust_caliptra_crates//:caliptra-cfi-derive",
    ],
    rustc_flags = ["--cap-lints=allow"],
    deps = [
        ":caliptra_cfi_lib",
        "//third_party/caliptra:crate_bitfield",
        "//third_party/caliptra:crate_bitflags",
        "//third_party/caliptra:crate_cfg-if",
        "//third_party/caliptra:crate_zerocopy",
        "//third_party/caliptra:crate_zeroize",
        "@rust_caliptra_crates//:arrayvec",
        "@rust_caliptra_crates//:caliptra-api",
        "@rust_caliptra_crates//:caliptra-error",
        "@rust_caliptra_crates//:caliptra-image-types",
        "@rust_caliptra_crates//:caliptra-lms-types",
        "@rust_caliptra_crates//:caliptra-okref",
        "@rust_caliptra_crates//:caliptra-registers",
        "@rust_caliptra_crates//:ufmt",
        "@rust_caliptra_crates//:ureg",
    ],
)

# caliptra_drivers variant with "runtime" feature for the Caliptra Runtime
# binary. The "runtime" feature enables typed access to DPE, PCR-reset, and
# auth-manifest fields in PersistentData (otherwise they're opaque [u8; N]).
rust_library(
    name = "caliptra_drivers_runtime",
    srcs = ["@caliptra_sw//:all_files"],
    crate_features = ["runtime"],
    crate_name = "caliptra_drivers",
    crate_root = "@caliptra_sw//:drivers/src/lib.rs",
    edition = "2021",
    proc_macro_deps = [
        "@rust_caliptra_crates//:caliptra-cfi-derive",
        "@rust_caliptra_crates//:caliptra-cfi-derive-git",
    ],
    rustc_flags = ["--cap-lints=allow"],
    # Pinned to the caliptra target platform because its transitive dep on
    # @rust_caliptra_crates//:caliptra_dpe (and that repo's zerocopy / zeroize)
    # only aligns cleanly with the rest of caliptra-sw under riscv32imc.  On
    # host triples the //third_party/caliptra:crate_zerocopy select routes to
    # @rust_caliptra_crates_host, which does not match the embedded-repo
    # zerocopy pulled in through caliptra_dpe (duplicate-crate trait errors).
    target_compatible_with = ["//third_party/caliptra/platforms:target_caliptra"],
    deps = [
        ":caliptra_cfi_lib",
        "//third_party/caliptra:crate_bitfield",
        "//third_party/caliptra:crate_bitflags",
        "//third_party/caliptra:crate_cfg-if",
        "//third_party/caliptra:crate_zerocopy",
        "//third_party/caliptra:crate_zeroize",
        "@rust_caliptra_crates//:arrayvec",
        "@rust_caliptra_crates//:caliptra-api",
        "@rust_caliptra_crates//:caliptra-auth-man-types",
        "@rust_caliptra_crates//:caliptra-cfi-lib-git",
        "@rust_caliptra_crates//:caliptra-error",
        "@rust_caliptra_crates//:caliptra-image-types",
        "@rust_caliptra_crates//:caliptra-lms-types",
        "@rust_caliptra_crates//:caliptra-okref",
        "@rust_caliptra_crates//:caliptra-registers",
        "@rust_caliptra_crates//:caliptra_dpe",
        "@rust_caliptra_crates//:ufmt",
        "@rust_caliptra_crates//:ureg",
    ],
)

