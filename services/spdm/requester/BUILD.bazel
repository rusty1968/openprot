load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "spdm_requester_lib",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "openprot_spdm_requester",
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        "//services/spdm/transport-mctp:spdm_transport_mctp",
        "@rust_crates//:heapless",
        "@rust_crates//:spdm-lib",
    ],
)

rust_test(
    name = "spdm_requester_test",
    crate = ":spdm_requester_lib",
)

# Host integration test: SPDM VCA flow with in-memory MCTP transport.
# Uses the same pattern as //services/mctp/server:mctp_server_echo_test.
rust_test(
    name = "spdm_requester_vca_host_test",
    srcs = [
        "tests/common/mod.rs",
        "tests/vca_host.rs",
    ],
    crate_root = "tests/vca_host.rs",
    edition = "2024",
    deps = [
        "//services/mctp/api:mctp_api",
        "//services/mctp/server:mctp_server_lib",
        "//services/spdm/transport-mctp:spdm_transport_mctp",
        "@rust_crates//:mctp",
        "@rust_crates//:mctp-lib",
        "@rust_crates//:spdm-lib",
        "@rust_crates//:zerocopy",
    ],
)
